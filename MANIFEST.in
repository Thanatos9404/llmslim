# Source distribution manifest for llmslim
include LICENSE
include README.md
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include SECURITY.md
include CITATION.cff
include pyproject.toml
include llmslim/py.typed

recursive-include assets *.svg *.png *.json *.py
recursive-include llmslim *.py

# Exclude scratch, build, test, and hidden cache directories from source packages
recursive-exclude tests *
recursive-exclude benchmarks *
recursive-exclude datasets *
recursive-exclude notebooks *
recursive-exclude .github *
recursive-exclude .pytest_cache *
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
